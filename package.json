{
  "name": "quadcore-smart-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsc --outDir .next/domain-tests --rootDir . --module commonjs --moduleResolution node --target ES2022 --noEmit false --isolatedModules false --incremental false --esModuleInterop true --strict true --skipLibCheck true domains/catalog/types/product.aggregate.test.ts && node --test .next/domain-tests/domains/catalog/types/product.aggregate.test.js && npm run test:task-review",
    "test:task-review": "tsx --test scripts/task-review/__tests__/*.test.ts",
    "review:bundle": "tsx scripts/task-review/create-task-review-bundle.ts",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "test:integration": "tsc --project tsconfig.integration.json && node --test .next/integration-tests/domains/catalog/infrastructure/persistence/integration-test-database-safety.test.js .next/integration-tests/domains/catalog/infrastructure/persistence/product-persistence.mapper.test.js .next/integration-tests/domains/catalog/infrastructure/persistence/postgresql-product.repository.integration.test.js"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fflate": "^0.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
