          "value": "\"catalog_products\".\"has_classification\" OR (\"catalog_products\".\"category_id\" IS NULL AND \"catalog_products\".\"product_type_id\" IS NULL AND \"catalog_products\".\"device_class_id\" IS NULL AND \"catalog_products\".\"condition_id\" IS NULL AND \"catalog_products\".\"availability_status_id\" IS NULL)"
